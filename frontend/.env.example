# Frontend env (optional – defaults to localhost in dev)
# For production, set in Vercel/Netlify dashboard:
VITE_API_URL=https://your-backend-url.com/api

# Google Sign-In: create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Use "Web application" type and add your frontend origin (e.g. http://localhost:5173, https://your-app.vercel.app)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
